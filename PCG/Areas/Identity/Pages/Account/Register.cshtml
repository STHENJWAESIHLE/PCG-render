@page
@model RegisterModel
@{
    ViewData["Title"] = "Register";
}

<div class="pcg-page-header">
    <h1 class="pcg-title">@ViewData["Title"]</h1>
    <p class="text-muted mb-0">Create an external user account to upload your credit notes.</p>
</div>

<div class="row justify-content-center">
    <div class="col-lg-6">
        <section class="pcg-card">
            <form id="registerForm" asp-route-returnUrl="@Model.ReturnUrl" method="post">
                <div asp-validation-summary="ModelOnly" class="text-danger small" role="alert"></div>

                <div class="form-floating mb-3">
                    <input asp-for="Input.Email" class="form-control" autocomplete="username" aria-required="true" placeholder="name@example.com" />
                    <label asp-for="Input.Email">Email</label>
                    <span asp-validation-for="Input.Email" class="text-danger small"></span>
                </div>

                <div class="form-floating mb-3">
                    <input asp-for="Input.Password" class="form-control" autocomplete="new-password" aria-required="true" placeholder="password" />
                    <label asp-for="Input.Password">Password</label>
                    <span asp-validation-for="Input.Password" class="text-danger small"></span>
                </div>

                <div class="form-floating mb-3">
                    <input asp-for="Input.ConfirmPassword" class="form-control" autocomplete="new-password" aria-required="true" placeholder="password" />
                    <label asp-for="Input.ConfirmPassword">Confirm Password</label>
                    <span asp-validation-for="Input.ConfirmPassword" class="text-danger small"></span>
                </div>

                <div class="alert alert-info small">
                    <strong>Note:</strong> External users can upload invoices and credit notes, but cannot approve documents. 
                    Uploaded documents will be routed through the approval workflow (Reviewer → Manager → Admin).
                </div>

                <button id="registerSubmit" type="submit" class="w-100 btn btn-lg btn-primary">Register as External User</button>

                <div class="mt-3">
                    <a asp-page="./Login" class="text-decoration-none">Already have an account? Log in</a>
                </div>
            </form>
        </section>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
