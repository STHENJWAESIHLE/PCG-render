@page
@model LogoutModel
@{
    ViewData["Title"] = "Log out";
}

<div class="pcg-page-header">
    <h1 class="pcg-title">@ViewData["Title"]</h1>
    <p class="text-muted mb-0">Confirm you want to end your session.</p>
</div>

<div class="row justify-content-center">
    <div class="col-lg-6">
        <section class="pcg-card">
            @if (User.Identity?.IsAuthenticated ?? false)
            {
                <form asp-area="Identity" asp-page="/Account/Logout" asp-route-returnUrl="@Url.Content("~/")" method="post">
                    <button type="submit" class="w-100 btn btn-primary">Log out</button>
                </form>
            }
            else
            {
                <p class="mb-0">You have successfully logged out.</p>
                <div class="mt-3">
                    <a class="btn btn-outline-secondary" asp-area="" asp-controller="Home" asp-action="Index">Back to home</a>
                </div>
            }
        </section>
    </div>
</div>
