<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - PCG MindRift DMS</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:ital,wght@0,400;0,500;0,600;0,700;1,400&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/theme/tokens.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/theme/layout.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/theme/components.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/PCG.styles.css" asp-append-version="true" />
</head>
<body class="pcg-app">
    <header>
        <nav class="navbar navbar-expand-sm navbar-light pcg-navbar mb-0">
            <div class="container">
                <a class="navbar-brand d-flex align-items-center flex-wrap" asp-area="" asp-controller="Home" asp-action="Index">
                    <span class="pcg-brand-mark">PCG</span><span class="pcg-brand-divider">|</span><span class="pcg-brand-sub">MindRift</span>
                </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1 align-items-sm-center">
                        <li class="nav-item">
                            <a class="nav-link" asp-area="" asp-controller="Home" asp-action="Index">Home</a>
                        </li>
                        @if (!User.IsInRole("ExternalUser"))
                        {
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Documents" asp-action="Index">All Documents</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Reports" asp-action="Index">Reports</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Insights" asp-action="Index">AI insights</a>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Documents" asp-action="Index">My Documents</a>
                            </li>
                        }
                        @if (User.CanUpload())
                        {
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Documents" asp-action="Upload">Upload</a>
                            </li>
                        }
                        <li class="nav-item">
                            <a class="nav-link" asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
                        </li>
                    </ul>
                    <partial name="_LoginPartial" />
                </div>
            </div>
        </nav>
    </header>
    <div class="container pcg-main-inner">
        <main role="main">
            @if (TempData["Message"] is string msg)
            {
                <div class="alert alert-success alert-dismissible fade show mt-3" role="alert">@msg<button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button></div>
            }
            @if (TempData["Error"] is string err)
            {
                <div class="alert alert-danger alert-dismissible fade show mt-3" role="alert">@err<button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button></div>
            }
            @RenderBody()
        </main>
    </div>

    <footer class="pcg-footer">
        <div class="container pcg-footer-inner">
            &copy; 2026 <strong>PCG</strong> | MindRift — document management. <a asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
