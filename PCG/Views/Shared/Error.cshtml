@model ErrorViewModel
@{
    ViewData["Title"] = "Error";
}

<div class="pcg-page-header">
    <h1 class="pcg-title text-danger">Something went wrong</h1>
    <p class="text-muted mb-0">An error occurred while processing your request.</p>
</div>

<div class="pcg-card">
    @if (Model.ShowRequestId)
    {
        <p class="mb-2">
            <span class="fw-semibold">Request ID:</span> <span class="pcg-code">@Model.RequestId</span>
        </p>
    }
    <h2 class="h6 fw-bold mt-3">Development mode</h2>
    <p class="small text-muted mb-0">
        Swapping to <strong>Development</strong> shows more detail about the error. Do not enable Development in production.
        Set <span class="pcg-code">ASPNETCORE_ENVIRONMENT</span> to <span class="pcg-code">Development</span> for local debugging.
    </p>
</div>
